{
  "$schema": "https://raw.githubusercontent.com/Bedrock-OSS/regolith-schemas/main/config/v1.7.json",
  "formatVersion": "1.7.0",
  "author": "test",
  "name": "test",
  "packs": {
    "behaviorPack": "./packs/BP",
    "resourcePack": "./packs/RP"
  },
  "regolith": {
    "dataPath": "./data",
    "filterDefinitions": {
      "replacements": {
        "runWith": "python",
        "script": "../replacements.py"
      }
    },
    "profiles": {
      "default": {
        "export": {
          "build": "standard",
          "readOnly": false,
          "target": "local"
        },
        "filters": [
          {
            "filter": "replacements",
            "extraArguments": "append",
            "settings": {
              "replace": {
                "fizz": "buzz",
                "foo": "bar"
              }
            }
          }
        ]
      }
    }
  }
}
