{
  "name": "bedrock-kit",
  "version": "1.0.1",
  "description": "A typed API for navigating Minecraft Bedrock addon files. Works in Node.js and browsers.",
  "type": "module",
  "main": "./dist/bedrockKit.js",
  "types": "./dist/bedrockKit.d.ts",
  "exports": {
    ".": {
      "import": "./dist/bedrockKit.js",
      "types": "./dist/bedrockKit.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node test/bedrockKit.test.js",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0",
    "typedoc": "^0.28.0"
  },
  "keywords": [
    "minecraft",
    "bedrock",
    "addon",
    "behavior-pack",
    "resource-pack"
  ],
  "license": "MIT"
}
